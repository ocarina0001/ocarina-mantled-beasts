        <apparel>
            <wornGraphicPath>Things/Pawn/Humanlike/Apparel/IndustrialMantle/IndustrialMantle</wornGraphicPath>
            <tags>
                <li>OCARINA_ApparelMantle</li>
            </tags>
        </apparel>
        <stuffCategories>
            <li>Metallic</li>
        </stuffCategories>
        <costStuffCount>30</costStuffCount>
        <costList>
            <ComponentIndustrial>1</ComponentIndustrial>
        </costList>
    </ThingDef>

    <ThingDef ParentName="OCARINA_MantledBeastsMantleBase">
        <defName>OCARINA_Apparel_ArmoredMantle</defName>
        <label>armored visor</label>
        <description>A wearable visor made specifically for the Va'ji (other xenotypes cannot wear these visors), this visor is created for use in war time, being much sturdier and protective than the technologically equivalent industrial mantel, trading off labor skill for combat prowess. Still, an improvement to the Va'jis' natural limitations. \n\nVisors are important parts of Va'ji society, much like clothing is to other xenotypes. Va'ji prefer to wear their visors for most of their lives, as they function not only as fashion and individual expression, but as utility to help improve their poor eyesight and improve communication.</description>
        <techLevel>Industrial</techLevel>
        <thingClass>MantledBeasts.Apparel_MoodTexture</thingClass>
