            <texPath>Things/Pawn/Humanlike/Apparel/IndustrialMantle/IndustrialMantle</texPath>
            <graphicClass>Graphic_Single</graphicClass>
        </graphicData>
        <statBases>
            <WorkToMake>3000</WorkToMake>
            <MaxHitPoints>100</MaxHitPoints>
            <Mass>0.5</Mass>
            <StuffEffectMultiplierArmor>0.28</StuffEffectMultiplierArmor>
            <StuffEffectMultiplierInsulation_Cold>0.18</StuffEffectMultiplierInsulation_Cold>
            <StuffEffectMultiplierInsulation_Heat>0</StuffEffectMultiplierInsulation_Heat>
