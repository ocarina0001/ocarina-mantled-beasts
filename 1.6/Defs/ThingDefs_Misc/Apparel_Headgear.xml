            <PainShockThreshold>0.1</PainShockThreshold>
            <MeleeCooldownFactor>0.08</MeleeCooldownFactor>
            <MeleeHitChance>0.16</MeleeHitChance>
            <ArrestSuccessChance>0.10</ArrestSuccessChance>
            <ShootingAccuracyFactor_Touch>0.16</ShootingAccuracyFactor_Touch>
            <ShootingAccuracyFactor_Short>0.12</ShootingAccuracyFactor_Short>
            <ShootingAccuracyFactor_Medium>0.08</ShootingAccuracyFactor_Medium>
            <ShootingAccuracyFactor_Long>0.04</ShootingAccuracyFactor_Long>
            <RangedCooldownFactor>0.08</RangedCooldownFactor>
