        </tradeTags>
        <comps>
            <li Class="VEF.Apparels.CompProperties_ApparelHediffs">
                <hediffDefnames>
                    <li>OCARINA_ArchotechMantlegearHediff</li>
                </hediffDefnames>
            </li>
        </comps>
    </ThingDef>

