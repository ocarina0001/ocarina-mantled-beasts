            <Mass>0.25</Mass>
            <StuffEffectMultiplierArmor>0.60</StuffEffectMultiplierArmor>
            <StuffEffectMultiplierInsulation_Cold>0.48</StuffEffectMultiplierInsulation_Cold>
            <StuffEffectMultiplierInsulation_Heat>0.48</StuffEffectMultiplierInsulation_Heat>
            <EquipDelay>2.0</EquipDelay>
        </statBases>
        <equippedStatOffsets>
            <SocialImpact>0.4</SocialImpact>
            <MoveSpeed>0.3</MoveSpeed>
            <GeneralLaborSpeed>0.32</GeneralLaborSpeed>
            <WorkSpeedGlobal>0.32</WorkSpeedGlobal>
        </equippedStatOffsets>
        <apparel>
            <bodyPartGroups>
                <li>Torso</li>
            </bodyPartGroups>
            <wornGraphicPath>Things/Pawn/Humanlike/Apparel/ArchotechMantlegear/Naked</wornGraphicPath>
            <layers>
                <li>OnSkin</li>
