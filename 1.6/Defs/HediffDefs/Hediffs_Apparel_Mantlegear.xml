    <HediffDef Name="OCARINA_MantledBeastsMantlegearHediffBase" ParentName="AddedBodyPartBase" Abstract="True">
        <label>mantlegear tail</label>
        <description>The tail of the mantlegear; non-Va'ji don't wear the tail piece, but Va'ji do.</description>
        <hediffClass>HediffWithComps</hediffClass>
        <allowMothballIfLowPriorityWorldPawn>true</allowMothballIfLowPriorityWorldPawn>
        <scenarioCanAdd>false</scenarioCanAdd>
        <maxSeverity>1.0</maxSeverity>
        <isBad>false</isBad>
    </HediffDef>

