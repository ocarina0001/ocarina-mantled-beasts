    <HediffDef ParentName="OCARINA_MantledBeastsMantlegearHediffBase">
        <defName>OCARINA_TribalMantlegearHediff</defName>
        <renderNodeProperties>
            <li>
                <workerClass>MantledBeasts.PawnRenderNodeWorker_AttachmentBody_GeneLockClothingColored</workerClass>
                <nodeClass>MantledBeasts.PawnRenderNode_ClothingColored</nodeClass>
                <!-- <workerClass>PawnRenderNodeWorker_AttachmentBody</workerClass> -->
                <texPath>Things/Pawn/Humanlike/Apparel/TribalMantlegear/Tail/Tail</texPath>
                <shaderTypeDef>CutoutComplex</shaderTypeDef>
                <colorType>Custom</colorType>
                <overrideMeshSize>(1.2,1.2)</overrideMeshSize>
                <parentTagDef>Body</parentTagDef>
                <rotDrawMode>Fresh,Rotting</rotDrawMode>
                <drawData>
                    <scaleOffsetByBodySize>true</scaleOffsetByBodySize>
                    <defaultData>
                        <layer>1</layer>
                    </defaultData>
                    <dataNorth>
                        <offset>(0.05,0,-0.70)</offset>
                        <layer>91</layer>
                    </dataNorth>
                    <dataSouth>
                        <offset>(-0.1,0,-0.18)</offset>
                    </dataSouth>
                    <dataEast>
                        <offset>(-0.55,0,-0.40)</offset>
                    </dataEast>
                    <dataWest>
                        <offset>(0.55,0,-0.40)</offset>
                    </dataWest>
                </drawData>
            </li>
        </renderNodeProperties>
    </HediffDef>
