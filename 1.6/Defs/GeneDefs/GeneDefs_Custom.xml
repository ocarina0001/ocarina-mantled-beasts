<?xml version="1.0" encoding="UTF-8"?>
<Defs>

    <GeneDef ParentName="GeneHandsBase">
        <defName>OCARINA_MantledBeastsPaws</defName>
        <label>va'ji paws</label>
        <description>Fluffy paws with pads at the ends of one's arms and legs. Consisting of either four fingers (including thumb) or four toes, these paws help with overall speed and stealth, with the sharp claws at the ends allowing for greater protection.</description>
        <iconPath>UI/Icons/Genes/Gene_MantledBeastsPaws</iconPath>
        <displayOrderInCategory>320</displayOrderInCategory>
        <biostatCpx>4</biostatCpx>
        <biostatMet>-3</biostatMet>
        <displayCategory>OCARINA_Cosmetic_MantledBeasts</displayCategory>
        <capMods>
            <li>
                <capacity>Manipulation</capacity>
                <postFactor>0.90</postFactor>
            </li>
        </capMods>
        <statOffsets>
            <HuntingStealth>0.35</HuntingStealth>
            <MoveSpeed>0.1</MoveSpeed>
        </statOffsets>
        <statFactors>
            <MoveSpeed>1.25</MoveSpeed>
            <VEF_MassCarryCapacity>0.5</VEF_MassCarryCapacity>
            <CarryingCapacity>0.5</CarryingCapacity>
        </statFactors>
        <symbolPack>
            <prefixSymbols>
                <li>
                    <symbol>pawed</symbol>
                </li>
            </prefixSymbols>
        </symbolPack>
        <modExtensions>
            <li Class="VEF.Genes.GeneExtension">
                <backgroundPathEndogenes>UI/Icons/Genes/AG_Endogenes</backgroundPathEndogenes>
                <backgroundPathXenogenes>UI/Icons/Genes/AG_Xenogenes</backgroundPathXenogenes>
                <hediffsToBodyParts>
                    <li>
                        <hediff>OCARINA_MantledBeastsPaws</hediff>
                        <bodyparts>
                            <li>Hand</li>
                            <li>Hand</li>
                            <li>Foot</li>
                            <li>Foot</li>
                        </bodyparts>
                    </li>
                </hediffsToBodyParts>
            </li>
        </modExtensions>
    </GeneDef>

    <GeneDef>
        <defName>OCARINA_MantledBeastsEyesight</defName>
        <label>va'ji eyesight</label>
        <description>Carriers of this gene have particularly poor eyesight.</description>
        <iconPath>UI/Icons/Genes/Gene_MantledBeastsEyes</iconPath>
        <displayCategory>OCARINA_Cosmetic_MantledBeasts</displayCategory>
        <displayOrderInCategory>51</displayOrderInCategory>
        <biostatMet>4</biostatMet>
        <biostatCpx>3</biostatCpx>
        <selectionWeight>0</selectionWeight>
        <exclusionTags>
            <li>ShootingAccuracy</li>
            <li>EyeColor</li>
        </exclusionTags>
        <symbolPack>
            <prefixSymbols>
                <li>
                    <symbol>blind</symbol>
                </li>
                <li>
                    <symbol>blur</symbol>
                </li>
                <li>
                    <symbol>squint</symbol>
                </li>
                <li>
                    <symbol>peek</symbol>
                </li>
                <li>
                    <symbol>cross</symbol>
                </li>
            </prefixSymbols>
            <suffixSymbols>
                <li>
                    <symbol>sighter</symbol>
                </li>
                <li>
                    <symbol>peeker</symbol>
                </li>
            </suffixSymbols>
        </symbolPack>
        <modExtensions>
            <li Class="VEF.Genes.GeneExtension">
                <backgroundPathEndogenes>UI/Icons/Genes/AG_Endogenes</backgroundPathEndogenes>
                <backgroundPathXenogenes>UI/Icons/Genes/AG_Xenogenes</backgroundPathXenogenes>
                <hediffsToBodyParts>
                    <li>
                        <hediff>OCARINA_MantledBeastsEyesight</hediff>
                        <bodyparts>
                            <li>Eye</li>
                            <li>Eye</li>
                        </bodyparts>
                    </li>
                </hediffsToBodyParts>
            </li>
        </modExtensions>
    </GeneDef>



</Defs>