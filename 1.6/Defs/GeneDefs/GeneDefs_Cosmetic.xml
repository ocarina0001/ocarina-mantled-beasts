<?xml version="1.0" encoding="UTF-8"?>
<Defs>

    <GeneDef Name="OCARINA_MantledBeastsFurBase" Abstract="True">
        <geneClass>MantledBeasts.FurGene</geneClass>
        <biostatCpx>0</biostatCpx>
        <displayCategory>OCARINA_Cosmetic_MantledBeasts</displayCategory>
        <displayOrderInCategory>111</displayOrderInCategory>
        <canGenerateInGeneSet>true</canGenerateInGeneSet>
        <iconColor>(0.75,0.75,0.75)</iconColor>
        <exclusionTags>
            <li>Skin</li>
            <li>SkinColorOverride</li>
            <li>Fur</li>
            <li>BeardStyle</li>
            <li>Bodies</li>
            <li>Body</li>
        </exclusionTags>
        <hairTagFilter>
            <whitelist>false</whitelist>
            <tags>
                <li>Shaved</li>
            </tags>
        </hairTagFilter>
        <beardTagFilter>
            <whitelist>true</whitelist>
            <tags>
                <li>NoBeard</li>
            </tags>
        </beardTagFilter>
        <skinIsHairColor>false</skinIsHairColor>
        <tattoosVisible>true</tattoosVisible>
        <renderNodeProperties>
            <li>
                <nodeClass>PawnRenderNode_Fur</nodeClass>
                <workerClass>PawnRenderNodeWorker_Fur</workerClass>
                <shaderTypeDef>CutoutComplex</shaderTypeDef>
                <baseLayer>5</baseLayer>
                <rotDrawMode>Fresh,Rotting</rotDrawMode>
                <colorType>Skin</colorType>
                <parentTagDef>Body</parentTagDef>
            </li>
        </renderNodeProperties>
    </GeneDef>

    <GeneDef ParentName="OCARINA_MantledBeastsFurBase">
        <defName>OCARINA_MantledBeastsFur</defName>
        <label>va'ji fur</label>
        <labelShortAdj>va'ji furred</labelShortAdj>
        <description>Carriers of this gene appear to grow a specific beast-like fur, that of a Va'ji.</description>
        <iconPath>UI/Icons/Genes/Gene_MantledBeastsFur</iconPath>
        <skinColorOverride>(255,255,255)</skinColorOverride>
        <forcedHeadTypes>
            <li>OCARINA_MantledBeasts_Average_Male</li>
            <li>OCARINA_MantledBeasts_Average_Female</li>
        </forcedHeadTypes>
        <fur>OCARINA_MantledBeasts</fur>
        <modExtensions>
            <li Class="MantledBeasts.FurColors">
                <allowedFurColors>
                    <li>OCARINA_FurPreset_Drexus</li>
                    <li>OCARINA_FurPreset_Y2</li>
                    <li>OCARINA_FurPreset_Brom</li>
                    <li>OCARINA_FurPreset_Laceleaf</li>
                    <li>OCARINA_FurPreset_Nyx</li>
                    <li>OCARINA_FurPreset_Kraihy</li>
                    <li>OCARINA_FurPreset_Mitch</li>
                    <li>OCARINA_FurPreset_CrimeToaster</li>
                    <li>OCARINA_FurPreset_8Z</li>
                    <li>OCARINA_FurPreset_Shooshaa</li>
                    <li>OCARINA_FurPreset_Zetameow</li>
                    <li>OCARINA_FurPreset_Saltyexos</li>
                    <li>OCARINA_FurPreset_Xing1</li>
                    <li>OCARINA_FurPreset_Maxadisasta</li>
                    <li>OCARINA_FurPreset_51ut</li>
                    <li>OCARINA_FurPreset_Avin</li>
                    <li>OCARINA_FurPreset_Sterling</li>
                    <li>OCARINA_FurPreset_Kitsune</li>
                    <li>OCARINA_FurPreset_Inno</li>
                    <li>OCARINA_FurPreset_Kanebaal</li>
                    <li>OCARINA_FurPreset_Athena</li>
                    <li>OCARINA_FurPreset_Aphel</li>
                    <li>OCARINA_FurPreset_Stylas</li>
                    <li>OCARINA_FurPreset_Lino</li>
                    <li>OCARINA_FurPreset_Wren</li>
                    <li>OCARINA_FurPreset_Newt</li>
                    <li>OCARINA_FurPreset_Kuro</li>
                    <li>OCARINA_FurPreset_Cassidy</li>
                </allowedFurColors>
            </li>
            <li Class="MantledBeasts.ColorMasks">
                <allowedColorMasks>
                    <li>
                        <maskName>Default</maskName>
                        <selectionWeight>2.0</selectionWeight>
                    </li>
                    <li>
                        <maskName>Lines</maskName>
                        <selectionWeight>1.0</selectionWeight>
                    </li>
                    <li>
                        <maskName>Split</maskName>
                        <selectionWeight>0.2</selectionWeight>
                    </li>
                </allowedColorMasks>
            </li>
            <li Class="VEF.Genes.GeneExtension">
                <furHidesBody>true</furHidesBody>
            </li>
        </modExtensions>
        <statOffsets>
            <ComfyTemperatureMin>-3</ComfyTemperatureMin>
        </statOffsets>
    </GeneDef>

    <GeneDef Name="OCARINA_MantledBeastsEarsBase" ParentName="GeneEarsBase" Abstract="True">
        <biostatCpx>0</biostatCpx>
        <displayCategory>OCARINA_Cosmetic_MantledBeasts</displayCategory>
        <displayOrderInCategory>222</displayOrderInCategory>
        <canGenerateInGeneSet>true</canGenerateInGeneSet>
        <exclusionTags>
            <li>Ears</li>
        </exclusionTags>
    </GeneDef>

    <GeneDef ParentName="OCARINA_MantledBeastsEarsBase">
        <defName>OCARINA_MantledBeastsEars</defName>
        <label>va'ji ears</label>
        <description>Carriers of this gene have large, Va'ji ears.</description>
        <iconPath>UI/Icons/Genes/Gene_MantledBeastsEars</iconPath>
        <renderNodeProperties>
            <li>
                <nodeClass>PawnRenderNode_AttachmentHead</nodeClass>
                <workerClass>PawnRenderNodeWorker_FlipWhenCrawling</workerClass>
                <texPath>Things/Pawn/Humanlike/MantledBeasts/HeadAttachments/Ears/MantledBeastEars</texPath>
                <shaderTypeDef>CutoutComplex</shaderTypeDef>
                <colorType>Hair</colorType>
                <parentTagDef>Head</parentTagDef>
                <useRottenColor>true</useRottenColor>
                <rotDrawMode>Fresh,Rotting</rotDrawMode>
                <drawData>
                    <defaultData>
                        <layer>71</layer>
                    </defaultData>
                    <dataNorth>
                        <layer>63</layer>
                    </dataNorth>
                    <dataSouth>
                        <layer>63</layer>
                    </dataSouth>
                </drawData>
            </li>
            <li>
                <nodeClass>PawnRenderNode_AttachmentHead</nodeClass>
                <workerClass>PawnRenderNodeWorker_FlipWhenCrawling</workerClass>
                <texPath>Things/Pawn/Humanlike/MantledBeasts/HeadAttachments/Ears/MantledBeastEarsBack</texPath>
                <shaderTypeDef>CutoutComplex</shaderTypeDef>
                <colorType>Hair</colorType>
                <parentTagDef>Head</parentTagDef>
                <useRottenColor>true</useRottenColor>
                <rotDrawMode>Fresh,Rotting</rotDrawMode>
                <drawData>
                    <defaultData>
                        <layer>-70</layer>
                    </defaultData>
                    <dataNorth>
                        <layer>-70</layer>
                    </dataNorth>
                    <dataSouth>
                        <layer>-70</layer>
                    </dataSouth>
                </drawData>
            </li>
        </renderNodeProperties>
        <statOffsets>
            <ComfyTemperatureMax>3</ComfyTemperatureMax>
        </statOffsets>
        <capMods>
            <li>
                <capacity>Hearing</capacity>
                <postFactor>1.1</postFactor>
            </li>
        </capMods>
    </GeneDef>

    <GeneDef Name="OCARINA_MantledBeastsTailBase" ParentName="GeneTailBase" Abstract="True">
        <biostatCpx>0</biostatCpx>
        <displayCategory>OCARINA_Cosmetic_MantledBeasts</displayCategory>
        <iconColor>(0.75,0.75,0.75)</iconColor>
        <displayOrderInCategory>333</displayOrderInCategory>
        <canGenerateInGeneSet>true</canGenerateInGeneSet>
        <randomChosen>true</randomChosen>
        <exclusionTags>
            <li>Tail</li>
        </exclusionTags>
    </GeneDef>

    <GeneDef ParentName="OCARINA_MantledBeastsTailBase">
        <defName>OCARINA_MantledBeastsTail</defName>
        <label>va'ji tail</label>
        <description>Carriers of this gene have a Va'ji tail.</description>
        <iconPath>UI/Icons/Genes/Gene_MantledBeastsTail</iconPath>
        <renderNodeProperties>
            <li>
                <workerClass>PawnRenderNodeWorker_AttachmentBody</workerClass>
                <texPath>Things/Pawn/Humanlike/MantledBeasts/BodyAttachments/Tails/MantledBeastTail</texPath>
                <shaderTypeDef>CutoutComplex</shaderTypeDef>
                <colorType>Hair</colorType>
                <overrideMeshSize>(1.2,1.2)</overrideMeshSize>
                <parentTagDef>Body</parentTagDef>
                <rotDrawMode>Fresh,Rotting</rotDrawMode>
                <drawData>
                    <scaleOffsetByBodySize>true</scaleOffsetByBodySize>
                    <defaultData>
                        <layer>-2</layer>
                    </defaultData>
                    <dataNorth>
                        <offset>(0.05,0,-0.70)</offset>
                        <layer>90</layer>
                    </dataNorth>
                    <dataSouth>
                        <offset>(-0.1,0,-0.18)</offset>
                    </dataSouth>
                    <dataEast>
                        <offset>(-0.55,0,-0.40)</offset>
                    </dataEast>
                    <dataWest>
                        <offset>(0.55,0,-0.40)</offset>
                    </dataWest>
                </drawData>
            </li>
        </renderNodeProperties>
        <statOffsets>
            <MoveSpeed>0.05</MoveSpeed>
        </statOffsets>
    </GeneDef>

    <GeneDef ParentName="GeneHairStyleBase">
        <defName>OCARINA_MantledBeastsHair</defName>
        <label>va'ji fluff</label>
        <description>Carriers of this gene grow bestial va'ji hair fluff on and around their heads.</description>
        <iconPath>UI/Icons/Genes/Gene_MantledBeastsFur</iconPath>
        <displayCategory>OCARINA_Cosmetic_MantledBeasts</displayCategory>
        <iconColor>(0.75,0.75,0.75)</iconColor>
        <displayOrderInCategory>333</displayOrderInCategory>
        <hairTagFilter>
            <whitelist>true</whitelist>
            <tags>
                <li>OCARINA_Vaji</li>
                <li>Shaved</li>
            </tags>
        </hairTagFilter>
        <symbolPack>
            <prefixSymbols>
                <li>
                    <symbol>fluff</symbol>
                </li>
                <li>
                    <symbol>beast</symbol>
                </li>
                <li>
                    <symbol>furred</symbol>
                </li>
            </prefixSymbols>
            <suffixSymbols>
                <li>
                    <symbol>furred</symbol>
                </li>
                <li>
                    <symbol>fluffed</symbol>
                </li>
            </suffixSymbols>
        </symbolPack>
    </GeneDef>

</Defs>