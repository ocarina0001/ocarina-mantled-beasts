<?xml version="1.0" encoding="UTF-8"?>
<Defs>

    <IssueDef>
        <defName>OCARINA_VajiMantle</defName>
        <label>va'ji visor</label>
        <iconPath>UI/Issues/Nudity_Male</iconPath>
    </IssueDef>

    <PreceptDef>
        <defName>OCARINA_Vaji_Mantle_Mandatory</defName>
        <issue>OCARINA_VajiMantle</issue>
        <description>Va'ji should wear their visors at all times, not doing so shows a lack of decorum for the existing social structure.</description>
        <label>mandatory</label>
        <impact>High</impact>
        <displayOrderInIssue>130</displayOrderInIssue>
        <displayOrderInImpact>850</displayOrderInImpact>
        <comps>
            <li Class="PreceptComp_SituationalThought">
                <thought>OCARINA_NotWearingMantle</thought>
            </li>
            <li Class="PreceptComp_SituationalThought">
                <thought>OCARINA_NotWearingMantle_Social</thought>
            </li>
        </comps>
    </PreceptDef>

    <ThoughtDef>
        <defName>OCARINA_NotWearingMantle</defName>
        <workerClass>MantledBeasts.ThoughtWorker_Precept_VajiNotWearingMantle</workerClass>
        <stages>
            <li>
                <label>not wearing visor</label>
                <description>As a Va'ji, I should be wearing my visor to express myself, and I'm not.</description>
                <baseMoodEffect>-4</baseMoodEffect>
            </li>
        </stages>
    </ThoughtDef>
    <ThoughtDef>
        <defName>OCARINA_NotWearingMantle_Social</defName>
        <thoughtClass>Thought_SituationalSocial</thoughtClass>
        <workerClass>MantledBeasts.ThoughtWorker_Precept_VajiNotWearingMantleSocial</workerClass>
        <stages>
            <li>
                <label>no visor</label>
                <baseOpinionOffset>-4</baseOpinionOffset>
            </li>
        </stages>
    </ThoughtDef>


    <!-- mantlegear stuff -->

    <IssueDef>
        <defName>OCARINA_VajiMantlegear</defName>
        <label>va'ji mantlegear</label>
        <iconPath>UI/Issues/VajiIssue</iconPath>
    </IssueDef>

    <PreceptDef>
        <defName>OCARINA_Vaji_Mantlegear_Mandatory</defName>
        <issue>OCARINA_VajiMantlegear</issue>
        <description>Va'ji should wear their mantlegear at all times, not doing so shows a lack of decorum for the existing social structure, like a baseliner going to a bar in the nude.</description>
        <label>mandatory</label>
        <impact>High</impact>
        <displayOrderInIssue>130</displayOrderInIssue>
        <displayOrderInImpact>850</displayOrderInImpact>
        <comps>
            <li Class="PreceptComp_SituationalThought">
                <thought>OCARINA_NotWearingMantlegear</thought>
            </li>
            <li Class="PreceptComp_SituationalThought">
                <thought>OCARINA_NotWearingMantlegear_Social</thought>
            </li>
        </comps>
    </PreceptDef>

    <ThoughtDef>
        <defName>OCARINA_NotWearingMantlegear</defName>
        <workerClass>MantledBeasts.ThoughtWorker_Precept_VajiNotWearingMantlegear</workerClass>
        <stages>
            <li>
                <label>not wearing mantlegear</label>
                <description>As a Va'ji, I should be wearing my mantlegear to express myself, and I'm not.</description>
                <baseMoodEffect>-4</baseMoodEffect>
            </li>
        </stages>
    </ThoughtDef>
    <ThoughtDef>
        <defName>OCARINA_NotWearingMantlegear_Social</defName>
        <thoughtClass>Thought_SituationalSocial</thoughtClass>
        <workerClass>MantledBeasts.ThoughtWorker_Precept_VajiNotWearingMantlegearSocial</workerClass>
        <stages>
            <li>
                <label>no mantlegear</label>
                <baseOpinionOffset>-4</baseOpinionOffset>
            </li>
        </stages>
    </ThoughtDef>

</Defs>